{
  "version": 2,
  "routes": [
    {
      "src": "/api/gemini",
      "dest": "/api/gemini.js"
    },
    {
      "src": "/splash.png",
      "dest": "/splash.png"
    },
    {
      "src": "/tarot/(.*)",
      "dest": "/tarot/$1"
    },
    {
      "src": "/(.*)",
      "dest": "/index.html"
    }
  ]
}
